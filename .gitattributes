# Auto-detect text files and normalize line endings
* text=auto

# Force LF for web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Force LF for scripts
*.sh text eol=lf

# Force CRLF for Windows-only files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.ttf binary
*.woff binary
*.woff2binary